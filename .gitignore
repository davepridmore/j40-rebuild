.DS_Store
__pycache__/
*.pyc

# Local credentials, browser sessions, and machine caches.
.ai/
.playwright-mcp/
.wwebjs_cache/
.wwebjs_cache.backup_*/
.idea/workspace.xml
.idea/vcs.xml
client_secret*.json
*credentials*.json
*.pem
*.key

# OAuth/API token files. Keep import manifests and generated indexes, not live tokens.
data/raw/imports/**/token*.json*
data/raw/imports/**/api_key*

# Dependency/build caches.
node_modules/
tools/wweb-mcp-local/node_modules/
**/__pycache__/
.deploy/

# Local staging inboxes and transient working files.
data/inbox/photos/
data/inbox/takeout/
.tmp*
*.log
