  <body style="background-color: rgba(241, 241, 241, 1)">
    <div class="skip-scrolling"></div>
    <div id="image-container">
      <img
        loading="eager"
        fetchpriority="high"
        src="/images/background-img.png"
        id="img-lazy-page"
        style="pointer-events: none; position: absolute; top: 0; display: block; left: 0; z-index: -1"
      />
    </div>
    <script type="64596122df484ca9b2187477-text/javascript">
      const img = document.getElementById('img-lazy-page');
      const clickEvent = new MouseEvent('click', {
        bubbles: true,
        cancelable: true,
        view: window,
      });
      img.onload = function () {
        console.log('Image loaded successfully');
        img.click();
        img.dispatchEvent(clickEvent);
      };
    </script>
